APP_NAME=Job Tracker API
APP_ENV=dev
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# API server
HOST=0.0.0.0
PORT=8000

# Database (Part 2 will consume this directly)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobtracker
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://user:applicationssuck@localhost:5432/career_monitor
# Logging
LOG_LEVEL=INFO
LOG_JSON=false


# Redis/Celery (future phases)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ...existing code...
SCRAPER_RATE_LIMIT_RPS=5

GREENHOUSE_SOURCES=[{"company":"ExampleCo","board_token":"exampleco"}]
LEVER_SOURCES=[{"company":"ExampleCo","company_handle":"exampleco"}]
WORKDAY_SOURCES=[{"company":"ExampleCo","jobs_api_url":"https://example.wd5.myworkdayjobs.com/wday/cxs/example/careers/jobs"}]
ASHBY_SOURCES=[{"company":"ExampleCo","jobs_url":"https://jobs.ashbyhq.com/api/public/jobs/exampleco"}]